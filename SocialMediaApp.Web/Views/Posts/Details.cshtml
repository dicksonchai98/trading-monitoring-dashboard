@model SocialMediaApp.Web.Entities.Post
@{
    ViewData["Title"] = "Post Details";
    var comments = (IReadOnlyList<SocialMediaApp.Web.Entities.Comment>)ViewBag.Comments;
    var input = (SocialMediaApp.Web.ViewModels.CommentCreateViewModel)ViewBag.CommentInput;
}

<div class="row g-4">
    <div class="col-12 col-lg-8">
        <article class="tweet-card">
            <div class="tweet-row">
                <div class="tweet-avatar" aria-hidden="true">Y</div>
                <div class="tweet-body">
                    <div class="tweet-meta">
                        <span class="tweet-name">Community User</span>
                        <span class="tweet-handle">@("@social_user")</span>
                        <span class="tweet-dot">·</span>
                        <span class="tweet-time">@Model.CreatedAt.ToLocalTime().ToString("MMM d")</span>
                    </div>
                    <p class="tweet-content">@Model.Content</p>
                @if (!string.IsNullOrWhiteSpace(Model.Image))
                {
                        <img src="@Model.Image" class="tweet-media" alt="post image" />
                    }
                }
            </div>
        </article>
    </div>
    <div class="col-12 col-lg-4">
        <div class="tweet-card mb-3">
            <h6 class="tweet-side-title">Replies</h6>
                @if (!comments.Any())
                {
                <div class="text-muted">No replies yet.</div>
                }
                else
                {
                    @foreach (var c in comments)
                    {
                        <div class="tweet-reply mb-2">
                            <div class="tweet-reply-meta">@("@reply_user") · just now</div>
                            <div>@c.Content</div>
                        </div>
                    }
                }
            </div>

        @if (User.Identity?.IsAuthenticated == true)
        {
            <div class="tweet-card">
                <h6 class="tweet-side-title">Post your reply</h6>
                    <form asp-controller="Comments" asp-action="Create" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PostId" value="@input.PostId" />
                    <textarea class="form-control tweet-input mb-2" name="Content" rows="3" maxlength="2000" placeholder="Tweet your reply"></textarea>
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary tweet-btn-primary">Reply</button>
                    </div>
                    </form>
                </div>
        }
    </div>
</div>
