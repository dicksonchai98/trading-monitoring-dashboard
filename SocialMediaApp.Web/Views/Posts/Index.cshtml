@model IReadOnlyList<SocialMediaApp.Web.Entities.Post>
@{
    ViewData["Title"] = "Posts";
    var commentMap = ViewBag.CommentMap as Dictionary<int, IReadOnlyList<SocialMediaApp.Web.Entities.Comment>>
                     ?? new Dictionary<int, IReadOnlyList<SocialMediaApp.Web.Entities.Comment>>();
}

<div class="timeline-wrap">
    <div class="row g-0 justify-content-center">
        <div class="col-12 col-xl-8">
            <div class="tweet-card tweet-compose mb-3">
                <div class="tweet-row">
                    <div class="tweet-avatar" aria-hidden="true">Y</div>
                    <div class="tweet-body">
                        <h5 class="tweet-compose-title">What's happening?</h5>
                        <form asp-action="Create" method="post">
                            @Html.AntiForgeryToken()
                            <div class="mb-2">
                                <textarea class="form-control tweet-input" name="Content" rows="4" maxlength="5000" placeholder="Share your thoughts"></textarea>
                            </div>
                            <div class="mb-2">
                                <input class="form-control tweet-input" name="Image" maxlength="500" placeholder="Optional image URL" />
                            </div>
                            <div class="d-flex justify-content-end">
                                <button class="btn btn-primary tweet-btn-primary" type="submit">Post</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="tweet-empty">No posts yet. Be the first one to post.</div>
            }

            @foreach (var post in Model)
            {
                var comments = commentMap.TryGetValue(post.PostId, out var value)
                    ? value
                    : Array.Empty<SocialMediaApp.Web.Entities.Comment>();

                <article class="tweet-card mb-2" id="post-@post.PostId">
                    <div class="tweet-row">
                        <div class="tweet-avatar" aria-hidden="true">Y</div>
                        <div class="tweet-body">
                            <div class="tweet-meta">
                                <span class="tweet-name">Community User</span>
                                <span class="tweet-handle">@("@social_user")</span>
                                <span class="tweet-dot">·</span>
                                <span class="tweet-time">@post.CreatedAt.ToLocalTime().ToString("MMM d")</span>
                            </div>
                            <p class="tweet-content mb-2">@post.Content</p>

                            @if (!string.IsNullOrWhiteSpace(post.Image))
                            {
                                <img src="@post.Image" class="tweet-media mb-2" alt="post image" />
                            }

                            <div class="tweet-actions">
                                <a class="tweet-action" asp-action="Details" asp-route-id="@post.PostId">Thread</a>
                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <a class="tweet-action" asp-action="Edit" asp-route-id="@post.PostId">Edit</a>
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@post.PostId" />
                                        <button class="tweet-action tweet-action-danger" type="submit">Delete</button>
                                    </form>
                                }
                                else
                                {
                                    <a class="tweet-action" asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Posts">Edit</a>
                                    <a class="tweet-action tweet-action-danger" asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Posts">Delete</a>
                                }
                            </div>

                            <div class="tweet-inline-comments mt-3">
                                @if (comments.Count == 0)
                                {
                                    <div class="tweet-reply text-muted">No replies yet.</div>
                                }
                                else
                                {
                                    @foreach (var c in comments)
                                    {
                                        <div class="tweet-reply mb-2">
                                            <div class="tweet-reply-meta">@("@reply_user") · @c.CreatedAt.ToLocalTime().ToString("MMM d")</div>
                                            <div>@c.Content</div>
                                        </div>
                                    }
                                }

                                @if (User.Identity?.IsAuthenticated == true)
                                {
                                    <form asp-controller="Comments" asp-action="Create" method="post" class="mt-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="PostId" value="@post.PostId" />
                                        <textarea class="form-control tweet-input mb-2" name="Content" rows="2" maxlength="2000" placeholder="Tweet your reply"></textarea>
                                        <div class="d-flex justify-content-end">
                                            <button type="submit" class="btn btn-primary tweet-btn-primary">Reply</button>
                                        </div>
                                    </form>
                                }
                                else
                                {
                                    <a class="tweet-action" asp-controller="Account" asp-action="Login" asp-route-returnUrl="/Posts">Login to reply</a>
                                }
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    </div>
</div>
