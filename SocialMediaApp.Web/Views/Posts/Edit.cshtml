@model SocialMediaApp.Web.ViewModels.PostEditViewModel
@{
    ViewData["Title"] = "Edit Post";
}

<div class="row justify-content-center">
    <div class="col-12 col-xl-8">
        <div class="tweet-card">
            <h4 class="tweet-compose-title mb-3">Edit post</h4>
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="PostId" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                    <label asp-for="Content" class="form-label"></label>
                    <textarea asp-for="Content" class="form-control tweet-input" rows="5"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
                <div class="d-flex gap-2 justify-content-end">
                    <a asp-action="Index" class="btn btn-light border">Cancel</a>
                    <button class="btn btn-primary tweet-btn-primary" type="submit">Save</button>
                </div>
        </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
