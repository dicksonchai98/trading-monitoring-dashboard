# Copy this file to `.env.production` on EC2, then fill real secrets.
# Do not commit `.env.production`.

# ----------------------------
# Core runtime
# ----------------------------
DATABASE_URL_DOCKER=postgresql+psycopg://<db_user>:<db_password>@<db_host>:5432/<db_name>
REDIS_URL_DOCKER=redis://redis:6379/0
JWT_SECRET=<strong-random-secret>
OTP_HASH_SECRET=<strong-random-secret>
OPAQUE_TOKEN_HASH_SECRET=<strong-random-secret>
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800

# ----------------------------
# Frontend build/runtime
# Keep empty when API is proxied by same domain through nginx.
# Example: https://api.your-domain.com
# ----------------------------
VITE_API_BASE_URL=

# ----------------------------
# CORS and serving
# Must be explicit origin list when allow_credentials=true
# ----------------------------
SERVING_CORS_ALLOW_ORIGINS=https://your-domain.com,https://www.your-domain.com
SERVING_RATE_LIMIT_PER_MIN=120
SERVING_SSE_CONN_LIMIT=3
SERVING_HEARTBEAT_SECONDS=15
SERVING_POLL_INTERVAL_MS=1000
SERVING_ENV=prod
SERVING_DEFAULT_CODE=TXF
SERVING_DEFAULT_KBAR_MINUTES=240
SERVING_DEFAULT_METRIC_SECONDS=3600

# ----------------------------
# Ingestor
# ----------------------------
INGESTOR_ENABLED=true
INGESTOR_ENV=prod
INGESTOR_CODE=TXF
INGESTOR_QUOTE_TYPES=tick,bidask
INGESTOR_QUEUE_MAXSIZE=1024
INGESTOR_STREAM_MAXLEN=100000
INGESTOR_REDIS_RETRY_ATTEMPTS=3
INGESTOR_REDIS_RETRY_BACKOFF_MS=50
INGESTOR_RECONNECT_MAX_SECONDS=30
SHIOAJI_API_KEY=<shioaji-api-key>
SHIOAJI_SECRET_KEY=<shioaji-secret-key>
SHIOAJI_SIMULATION=false

# ----------------------------
# Stream aggregator worker
# Keep false on API process; dedicated worker handles aggregation.
# ----------------------------
AGGREGATOR_ENABLED=false
AGGREGATOR_ENV=prod
AGGREGATOR_CODE=TXF
AGGREGATOR_TICK_GROUP=agg:tick
AGGREGATOR_BIDASK_GROUP=agg:bidask
AGGREGATOR_TICK_CONSUMER=agg-tick-1
AGGREGATOR_BIDASK_CONSUMER=agg-bidask-1
AGGREGATOR_READ_COUNT=100
AGGREGATOR_BLOCK_MS=1000
AGGREGATOR_CLAIM_IDLE_MS=30000
AGGREGATOR_CLAIM_COUNT=100
AGGREGATOR_STATE_TTL_SECONDS=86400
AGGREGATOR_SERIES_FIELDS=bid,ask,mid,spread,delta_1s

# ----------------------------
# OTP / Email
# ----------------------------
OTP_CHANNEL=email
OTP_TTL_SECONDS=300
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_SEND_MAX_RETRIES=3
NOTIFICATION_SEND_MAX_RETRIES=5
OTP_VERIFICATION_TOKEN_TTL_SECONDS=600
OTP_FIXED_CODE_FOR_TESTS=
SENDGRID_API_KEY=<sendgrid-api-key>
SENDGRID_FROM_EMAIL=noreply@your-domain.com
SENDGRID_OTP_TEMPLATE_ID=<sendgrid-template-id>
SENDGRID_WEBHOOK_SIGNING_KEY=<sendgrid-webhook-signing-key>
EMAIL_STREAM_KEY=email:outbox:stream
EMAIL_STREAM_GROUP=email:worker
EMAIL_STREAM_CONSUMER=email-worker-1

# ----------------------------
# Stripe billing
# ----------------------------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_SUCCESS_URL=https://your-domain.com/success
STRIPE_CANCEL_URL=https://your-domain.com/cancel
STRIPE_PORTAL_RETURN_URL=https://your-domain.com/account/billing

# ----------------------------
# Historical backfill worker
# ----------------------------
BACKFILL_MAX_CONCURRENCY=2
BACKFILL_RETRY_MAX_ATTEMPTS=3
BACKFILL_RETRY_BACKOFF_SECONDS=1
BACKFILL_MAX_RANGE_DAYS=366
BACKFILL_WORKER_POLL_INTERVAL_SECONDS=5
BACKFILL_HEARTBEAT_INTERVAL_SECONDS=30
BACKFILL_FETCH_MIN_INTERVAL_SECONDS=1
