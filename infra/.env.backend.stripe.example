# Backend Stripe Billing (MVP)
# Copy to your environment-specific secret store or compose env file.

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_SUCCESS_URL=https://your-frontend.example.com/billing/success
STRIPE_CANCEL_URL=https://your-frontend.example.com/billing/cancel
STRIPE_PORTAL_RETURN_URL=https://your-frontend.example.com/account/billing

# Webhook endpoint (server side)
# POST /billing/webhooks/stripe
# Example local URL for Stripe CLI forwarding:
# http://localhost:8000/billing/webhooks/stripe
