## Backend environment example
## Copy this file to `.env` and replace placeholder values.

# Database
DATABASE_URL=sqlite+pysqlite:///./backend.db

# Auth
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800
REFRESH_COOKIE_NAME=refresh_token

# Stripe billing (required at app startup)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/account/billing

# Optional: used by scripts/seed_admin.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
