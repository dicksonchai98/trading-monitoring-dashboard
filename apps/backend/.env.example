## Backend environment example
## Copy this file to `.env` and replace placeholder values.

# Database
DATABASE_URL=sqlite+pysqlite:///./backend.db

# Batch worker (crawler/backfill)
WORKER_NAME=batch-worker
LOG_LEVEL=INFO
RETRY_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=2

# Auth
JWT_SECRET=dev-secret-change-me
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800
REFRESH_COOKIE_NAME=refresh_token

# Stripe billing (required at app startup)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/account/billing

# Redis
REDIS_URL=redis://localhost:6379/0
EMAIL_STREAM_KEY=email:outbox:stream
EMAIL_STREAM_GROUP=email:worker
EMAIL_STREAM_CONSUMER=email-worker-1

# Ingestor
INGESTOR_ENABLED=false
INGESTOR_ENV=dev
INGESTOR_CODE=MTX
INGESTOR_QUOTE_TYPES=tick,bidask
INGESTOR_QUEUE_MAXSIZE=1024
INGESTOR_STREAM_MAXLEN=100000
INGESTOR_REDIS_RETRY_ATTEMPTS=3
INGESTOR_REDIS_RETRY_BACKOFF_MS=50
INGESTOR_RECONNECT_MAX_SECONDS=30
INGESTOR_SPOT_SYMBOLS_FILE=infra/config/stock150.txt
INGESTOR_SPOT_SYMBOLS_EXPECTED_COUNT=150
INGESTOR_SPOT_REQUIRED=false
SHIOAJI_API_KEY=
SHIOAJI_SECRET_KEY=
SHIOAJI_SIMULATION=true

# Aggregator
AGGREGATOR_ENABLED=false
AGGREGATOR_ENV=dev
AGGREGATOR_CODE=MTX
AGGREGATOR_TICK_GROUP=agg:tick
AGGREGATOR_BIDASK_GROUP=agg:bidask
AGGREGATOR_TICK_CONSUMER=agg-tick-1
AGGREGATOR_BIDASK_CONSUMER=agg-bidask-1
AGGREGATOR_READ_COUNT=100
AGGREGATOR_BLOCK_MS=1000
AGGREGATOR_CLAIM_IDLE_MS=30000
AGGREGATOR_CLAIM_COUNT=100
AGGREGATOR_STATE_TTL_SECONDS=86400
AGGREGATOR_SERIES_FIELDS=bid,ask,mid,spread,delta_1s

# Serving API
SERVING_ENV=dev
SERVING_DEFAULT_CODE=
SERVING_POLL_INTERVAL_MS=500
SERVING_HEARTBEAT_SECONDS=15
SERVING_DEFAULT_KBAR_MINUTES=240
SERVING_DEFAULT_METRIC_SECONDS=3600
SERVING_RATE_LIMIT_PER_MIN=120
SERVING_SSE_CONN_LIMIT=3
SERVING_CORS_ALLOW_ORIGINS=http://localhost:3000

# KBar analytics cron worker
KBAR_ANALYTICS_RETRY_MAX_ATTEMPTS=3
KBAR_ANALYTICS_RETRY_BACKOFF_SECONDS=1
KBAR_ANALYTICS_CRON_ENABLED=false
KBAR_ANALYTICS_CRON_INTERVAL_SECONDS=86400
KBAR_ANALYTICS_CRON_WINDOW_DAYS=30
KBAR_ANALYTICS_CRON_CODE=TXF

# Optional: used by scripts/seed_admin.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# OTP + SendGrid email
OTP_CHANNEL=email
OTP_TTL_SECONDS=300
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_SEND_MAX_RETRIES=3
NOTIFICATION_SEND_MAX_RETRIES=5
OTP_VERIFICATION_TOKEN_TTL_SECONDS=600
OTP_HASH_SECRET=dev-otp-secret-change-me
OPAQUE_TOKEN_HASH_SECRET=dev-opaque-token-secret-change-me
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@example.com
SENDGRID_OTP_TEMPLATE_ID=d-your-sendgrid-template-id
SENDGRID_WEBHOOK_SIGNING_KEY=
